{
    "$schema": "https://mintlify.com/docs.json",
    "theme": "mint",
    "name": "Objectionly",
    "appearance": {
        "default": "light"
    },
    "colors": {
        "primary": "#002C72",
        "light": "#2B7FFF",
        "dark": "#155DFC"
    },
    "styling": {
        "eyebrows": "breadcrumbs"
    },
    "favicon": "/favicon-2.png",
    "navigation": {
        "tabs": [{
                "tab": "Guides",
                "groups": [{
                        "group": "Getting started",
                        "pages": [
                            "index"
                        ]
                    },
                    {
                        "group": "Team & Roles",
                        "pages": [
                            "team-and-roles/overview",
                            "team-and-roles/understanding-roles",
                            "team-and-roles/managing-reps",
                            {
                                "group": "Managing Team Members",
                                "expanded": false,
                                "pages": [
                                    "team-and-roles/managing-team-members",
                                    "team-and-roles/invite-a-member",
                                    "team-and-roles/invite-an-admin",
                                    "team-and-roles/change-a-role",
                                    "team-and-roles/remove-a-member"
                                ]
                            },
                            {
                                "group": "Rep Access for Members",
                                "expanded": false,
                                "pages": [
                                    "team-and-roles/how-rep-access-works",
                                    "team-and-roles/assign-rep-access"
                                ]
                            },
                            "team-and-roles/faq"
                        ]
                    },
                    {
                        "group": "Integrations",
                        "pages": [
                            "integrations/close-crm",
                            "integrations/quo",
                            "integrations/zoom",
                            "integrations/fathom",
                            "integrations/fireflies",
                            "integrations/ringcentral",
                            "integrations/justcall",
                            "integrations/leadconnector",
                            "integrations/gohighlevel",
                            "integrations/zapier"
                        ]
                    }
                ]
            },
            {
                "tab": "API reference",
                "groups": [{
                    "group": "API documentation",
                    "pages": [
                        "api-reference/introduction",
                        "api-reference/queue-call-processing"
                    ]
                }]
            }
        ]
    },
    "redirects": [{
        "source": "/introduction",
        "destination": "/"
    }],
    "logo": {
        "light": "/logo/android-chrome-512x512.png",
        "dark": "/logo/android-chrome-512x512.png"
    },
    "navbar": {
        "links": [{
            "label": "Support",
            "href": "mailto:team@objectionly.com"
        }],
        "primary": {
            "type": "button",
            "label": "Dashboard",
            "href": "https://app.objectionly.com"
        }
    },
    "contextual": {
        "options": [
            "copy",
            "view",
            "chatgpt",
            "claude",
            "perplexity",
            "mcp",
            "cursor",
            "vscode"
        ]
    },
    "footer": {
        "socials": {
            "linkedin": "https://www.linkedin.com/company/objectionly/"
        }
    }
}
